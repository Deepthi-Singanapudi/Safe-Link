{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "strict": false,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "./",
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./client/src/*"],  
      "@shared/*": ["./shared/*"]
},
    "types": ["node"]
  },
  "include": ["server/**/*", "shared/**/*", "client/src/**/*"]
}